# ============================================================
# MHPSS UA Dashboard — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real tokens.
#
# NOTE: KOBO_API_TOKEN is NOT here — it is stored as a
# Cloudflare Worker Secret (never in the JS bundle):
#   npx wrangler secret put KOBO_API_TOKEN
#
# ============================================================

# ActivityInfo — org-specific DB and Form IDs (non-sensitive, safe to commit)
# Get these from your ActivityInfo account after registration:
# https://www.activityinfo.org → Database → Form → URL bar → copy IDs
VITE_ACTIVITYINFO_DB_ID=
VITE_ACTIVITYINFO_FORM_ID=

# KoBo — specific form Asset ID (if auto-discovery doesn't find the right form)
# Get from: KoBo → your form → Settings → API → "uid" field
# If left empty, the dashboard auto-discovers the first MHPSS survey in the account
VITE_KOBO_ASSET_ID=
